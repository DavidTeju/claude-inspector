{
	"name": "claude-inspector",
	"version": "0.1.0",
	"description": "A local web UI for browsing, searching, and interacting with your Claude Code sessions",
	"type": "module",
	"bin": {
		"claude-inspector": "bin/cli.js"
	},
	"files": [
		"bin/",
		"build/"
	],
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"claude",
		"claude-code",
		"inspector",
		"session-viewer",
		"anthropic"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/DavidTeju/claude-inspector.git"
	},
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"prepublishOnly": "npm run build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"knip": "knip",
		"test": "vitest run --project unit",
		"test:watch": "vitest --project unit",
		"test:coverage": "vitest run --project unit --coverage",
		"test:storybook": "vitest run --project storybook",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.75",
		"@anthropic-ai/sdk": "^0.78.0",
		"@lucide/svelte": "^0.577.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@vscode/ripgrep": "^1.17.0",
		"better-sqlite3": "^12.6.2",
		"diff": "^8.0.3",
		"marked": "^15.0.0",
		"shiki": "^3.0.0"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.0.1",
		"@davidteju/dev-config": "github:DavidTeju/dev-config",
		"@storybook/addon-a11y": "^10.2.19",
		"@storybook/addon-docs": "^10.2.19",
		"@storybook/addon-svelte-csf": "^5.0.11",
		"@storybook/addon-vitest": "^10.2.19",
		"@storybook/sveltekit": "^10.2.19",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/diff": "^7.0.2",
		"@types/node": "^25.3.0",
		"@vitest/browser-playwright": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"eslint": "^10.0.0",
		"eslint-plugin-storybook": "^10.2.19",
		"eslint-plugin-svelte": "^3.15.2",
		"husky": "^9.1.7",
		"jsdom": "^29.0.0",
		"knip": "^5.86.0",
		"lint-staged": "^16.4.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"storybook": "^10.2.19",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	}
}
